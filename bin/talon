declare(strict_types=1);

use Phalcon\Talon\Cli\Kernel;

// Dev checkout: bin/../vendor; installed dependency: vendor/phalcon/talon/bin -> vendor.
foreach ([dirname(__DIR__) . '/vendor/autoload.php', dirname(__DIR__, 3) . '/autoload.php'] as $autoload) {
    if (file_exists($autoload)) {
        require $autoload;

        break;
    }
}

if (!class_exists(Kernel::class)) {
    fwrite(STDERR, 'talon: could not locate the composer autoloader.' . PHP_EOL);
    exit(1);
}

exit((new Kernel())->handle($_SERVER['argv'] ?? []));
