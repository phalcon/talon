# Docker / project
PROJECT_PREFIX=talon
PHP_VERSION=8.5
PHALCON_VARIANT=v5
UID=1000
GID=1000

# MySQL (host is the compose service name)
DATA_MYSQL_HOST=mysql
DATA_MYSQL_PORT=3306
DATA_MYSQL_USER=root
DATA_MYSQL_PASS=secret
DATA_MYSQL_NAME=talon
DATA_MYSQL_CHARSET=utf8mb4

# PostgreSQL
DATA_POSTGRES_HOST=pgsql
DATA_POSTGRES_PORT=5432
DATA_POSTGRES_USER=postgres
DATA_POSTGRES_PASS=secret
DATA_POSTGRES_NAME=talon
DATA_POSTGRES_SCHEMA=public

# SQLite (":memory:" or a path)
DATA_SQLITE_NAME=:memory:

# Redis
DATA_REDIS_HOST=redis
DATA_REDIS_PORT=6379
DATA_REDIS_NAME=1

# Memcached
DATA_MEMCACHED_HOST=memcached
DATA_MEMCACHED_PORT=11211
DATA_MEMCACHED_WEIGHT=0
