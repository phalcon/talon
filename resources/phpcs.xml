<?xml version="1.0"?>
<ruleset name="Talon">
    <description>Talon Coding Standards (PSR-12)</description>
    <arg value="-colors"/>
    <arg name="extensions" value="php"/>
    <rule ref="PSR12"/>
    <file>../src</file>
    <file>../tests</file>
    <!-- Mutation runs leave crash debris here that breaks traversal. -->
    <exclude-pattern>*/tests/_output/*</exclude-pattern>
</ruleset>
